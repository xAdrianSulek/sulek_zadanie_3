<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="sulek_zadanie_3.Views.ThirdPage"
             Title="Add transaction">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Add transaction"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label Text="Amount" />
            <Entry
                Placeholder="0.00"
                Keyboard="Numeric"
                Text="{Binding Amount}" />

            <Label Text="Category" />
            <Entry
                Placeholder="e.g. Groceries, Salary"
                Text="{Binding Category}" />

            <Label Text="Date" />
            <DatePicker Date="{Binding Date}" />

            <Label Text="Type" />
            <Picker
                ItemsSource="{Binding TransactionTypes}"
                SelectedItem="{Binding Type}" />

            <Label Text="Note (optional)" />
            <Editor
                Placeholder="Add a description..."
                AutoSize="TextChanges"
                Text="{Binding Note}" />

            <Button
                Text="Save Transaction"
                Command="{Binding SaveCommand}"
                Margin="0,10,0,0" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,15,0,0" />

            <Button
                Text="Home screen"
                Command="{Binding GoToMainCommand}" />

            <Button
                Text="Transaction List"
                Command="{Binding GoToSecondCommand}" />

            <Button
                Text="Statistics"
                Command="{Binding GoToFourthCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
