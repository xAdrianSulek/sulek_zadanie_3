<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="sulek_zadanie_3.MainPage"
             Title="Home screen">

    <Grid RowDefinitions="*,Auto" Padding="20" RowSpacing="15">

        <HorizontalStackLayout
            Grid.Row="0"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Spacing="20">

            <Border
                StrokeThickness="2"
                WidthRequest="140"
                HeightRequest="140">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="6">
                    <Label
                        Text="Income"
                        FontSize="16"
                        HorizontalOptions="Center" />
                    <Label
                        Text="{Binding TotalIncome, StringFormat='{0:N2} €'}"
                        FontSize="28"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <Border
                StrokeThickness="2"
                WidthRequest="140"
                HeightRequest="140">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="6">
                    <Label
                        Text="Expenses"
                        FontSize="16"
                        HorizontalOptions="Center" />
                    <Label
                        Text="{Binding TotalExpenses, StringFormat='{0:N2} €'}"
                        FontSize="28"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <Border
                StrokeThickness="2"
                WidthRequest="140"
                HeightRequest="140">
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="6">
                    <Label
                        Text="Balance"
                        FontSize="16"
                        HorizontalOptions="Center" />
                    <Label
                        Text="{Binding Balance, StringFormat='{0:N2} €'}"
                        FontSize="28"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Button
                Text="Transaction List"
                Command="{Binding GoToSecondCommand}" />
            <Button
                Text="Add transaction"
                Command="{Binding GoToThirdCommand}" />
            <Button
                Text="Statistics"
                Command="{Binding GoToFourthCommand}" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
